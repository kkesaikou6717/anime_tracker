# ============================================
# Anime Tracker 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# qBittorrent 登录密码
QB_PASSWORD=your_qb_password_here

# TMM HTTP API Key
TMM_API_KEY=your_tmm_api_key_here

# Server酱 SendKey
SERVERCHAN_SENDKEY=SCT189…DcSL

# ============================================
# 以下为可选配置，有默认值
# ============================================

# 临时下载目录（qBittorrent 保存路径）
# 默认: /volume1/Temp
# DOWNLOAD_TEMP_PATH=/volume1/Temp

# 最终存储目录（博哥已在 TMM 中指向此目录）
# 默认: /volume1/Video/已归档/Anime
# ANIME_ARCHIVE_PATH=/volume1/Video/已归档/Anime

# 做种最小比率
# 默认: 2.0
# SEEDING_MIN_RATIO=2.0

# 做种最小时长（小时），默认 24
# SEEDING_MIN_HOURS=24

# 日志级别
# LOG_LEVEL=INFO
