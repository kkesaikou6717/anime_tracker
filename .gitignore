# ============================================
# Anime Tracker — Git 忽略规则
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
*.egg

# 虚拟环境
venv/
.venv/
env/

# 环境变量（敏感信息）
.env
!.env.example

# 配置文件（含内网 IP 等敏感信息）
config/config.yaml
!config/config.yaml.example

# 数据库文件
*.db
*.sqlite
*.sqlite3

# 日志
data/logs/
*.log

# 运行时数据
data/

# Docker
.docker/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 测试
.pytest_cache/
.coverage
htmlcov/

# 临时文件
*.tmp
*.bak

# NAS 备份
*.v2bak
*.v2bak2
*.v3bak

# 部署包
*.tar.gz
*.tar.gz.b64
